# Container-tuned zsh config (oh-my-zsh + powerlevel10k).
# node/npm and JAVA_HOME are provided by the devcontainer (node feature writes
# /etc/zsh/zshrc; JAVA_HOME via containerEnv) -> NOT managed here, inherited.

# Powerlevel10k instant prompt (keep near top).
if [[ -r "${XDG_CACHE_HOME:-$HOME/.cache}/p10k-instant-prompt-${(%):-%n}.zsh" ]]; then
  source "${XDG_CACHE_HOME:-$HOME/.cache}/p10k-instant-prompt-${(%):-%n}.zsh"
fi

export ZSH="$HOME/.oh-my-zsh"
ZSH_THEME="powerlevel10k/powerlevel10k"
ZSH_AUTOSUGGEST_HIGHLIGHT_STYLE='fg=#707070'

plugins=(
  git
  sudo
  docker
  fzf
  fzf-tab
  zsh-autosuggestions
  zsh-syntax-highlighting
  colored-man-pages
)

source "$ZSH/oh-my-zsh.sh"

# p10k prompt config (reused from repo root .p10k.zsh, symlinked to ~).
[[ ! -f ~/.p10k.zsh ]] || source ~/.p10k.zsh

# fzf + rg/bat (only if present in the container; degrade gracefully).
if command -v rg >/dev/null 2>&1; then
  export FZF_DEFAULT_COMMAND='rg --files --hidden --follow --glob "!.git/*"'
  export FZF_CTRL_T_COMMAND="$FZF_DEFAULT_COMMAND"
  export FZF_ALT_C_COMMAND='rg --files --hidden --follow --glob "!.git/*" --type d'
fi
if command -v bat >/dev/null 2>&1; then
  export FZF_DEFAULT_OPTS='--height 40% --layout=reverse --preview "bat --style=numbers --color=always {} | head -100"'
else
  export FZF_DEFAULT_OPTS='--height 40% --layout=reverse'
fi

export LESS=FRX

alias llt='ls -alrht'
alias lls='ls -alrhS'
alias ccd='claude --dangerously-skip-permissions'
alias ccdr='claude --dangerously-skip-permissions --resume'
